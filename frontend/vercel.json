{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backupblogforum-production.up.railway.app/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://backupblogforum-production.up.railway.app/ws/:path*"
    }
  ],
  "routes": [
    {
      "src": "^/(?!api|ws|_next).*",
      "dest": "/index.html"
    }
  ]
}
